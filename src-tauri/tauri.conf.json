{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "0.0.4",
  "identifier": "com.tauri-app.app",
  "build": {
    "removeUnusedCommands": true,
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "tauri-app",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' tauri: ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' tauri: ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Your Name",
    "category": "DeveloperTool",
    "shortDescription": "A Tauri React template application",
    "longDescription": "A modern Tauri React template with comprehensive boilerplate code, TypeScript, Tailwind CSS, and shadcn/ui components.",
    "copyright": "Copyright © 2025 Your Name. All rights reserved.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/mautops/tauri2-template/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1NkJCMUE1NTQ1OEEzN0EKUldSNm8xaFVwYkZyMVNNMzBmeVk4ZjVLbmthTVp3ekcvQ245dkY4Yzkxd1BvcVF1K3dmVjA3eUkK"
    },
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["tauri-template"]
      }
    },
    "cli": {
      "description": "A Tauri app built from tauri-template",
      "args": [
        {
          "name": "reset-config",
          "short": "r",
          "description": "Reset all preferences to defaults",
          "takesValue": false
        },
        {
          "name": "log-level",
          "short": "l",
          "description": "Set log level (error, warn, info, debug, trace)",
          "takesValue": true,
          "possibleValues": ["error", "warn", "info", "debug", "trace"]
        },
        {
          "name": "debug",
          "short": "d",
          "description": "Enable debug mode (shows DevTools on startup)",
          "takesValue": false
        }
      ]
    }
  }
}
